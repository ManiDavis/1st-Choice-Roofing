# Copy this to .env.local for local development.
# Add these same variables in your Vercel project settings.

NEXT_PUBLIC_SANITY_PROJECT_ID=1dnw2j6i
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Create a read token at: https://www.sanity.io/manage -> project 1dnw2j6i -> API -> Tokens
SANITY_API_READ_TOKEN=

# Any random string — used to secure the /api/revalidate webhook from Sanity
SANITY_REVALIDATE_SECRET=1stchoice-roofing-revalidate-2024

# Your production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.1stchoice-roofing.com
